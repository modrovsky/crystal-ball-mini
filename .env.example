# Ethereum RPC endpoints — get free keys from Alchemy, Infura, Ankr, etc.

# HTTP RPC (required) — used for reading auction state + block data
RPC_URL_HTTP=https://eth.llamarpc.com

# WebSocket RPC (optional) — enables real-time block subscriptions
# Without this, the app falls back to polling every 12 seconds
# RPC_URL_WS=wss://your-provider.com/ws/your-key

# Historical noun seeds — enables trait matching against all past nouns.
# Set ONE of these (subgraph is checked first). Without either, trait matching is disabled.

# Nouns Subgraph (Goldsky / The Graph) — easiest option, no setup required
SUBGRAPH_ENDPOINT=https://api.goldsky.com/api/public/project_clnbcoajmebxn33wdbt98f439/subgraphs/nouns-mainnet/1.0.0/gn

# Ponder indexer (alternative) — if you run your own indexer
# PONDER_ENDPOINT=https://your-ponder-indexer.example.com
